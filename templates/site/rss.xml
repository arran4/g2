<?xml version="1.0" encoding="UTF-8" ?>
<rss version="2.0">
<channel>
  <title>{{.Title}}</title>
  <link>{{.Link}}</link>
  <description>{{.Description}}</description>
  <lastBuildDate>{{.LastBuildDate}}</lastBuildDate>
  {{range .Items}}
  <item>
    <title>{{.Title}}</title>
    <link>{{.Link}}</link>
    <description>{{.Description}}</description>
    <pubDate>{{.PubDate}}</pubDate>
  </item>
  {{end}}
</channel>
</rss>
