-- ebuild.ebuild --
EAPI=8
DESCRIPTION="Test ebuild"
HOMEPAGE="https://example.com"
SRC_URI="https://example.com/${P}.tar.gz"
LICENSE="MIT"
SLOT="0"
KEYWORDS="~amd64 ~x86"
IUSE=""
DEPEND=""
RDEPEND=""
BDEPEND=""

src_prepare() {
	default
	sed -i -e 's/foo/bar/g' Makefile || die
}

src_configure() {
	econf \
		--disable-static
}

src_compile() {
	emake
}

src_install() {
	emake DESTDIR="${D}" install
	einstalldocs
}
-- output.json --
{
	"Vars": {
		"BDEPEND": "",
		"DEPEND": "",
		"DESCRIPTION": "Test ebuild",
		"EAPI": "8",
		"HOMEPAGE": "https://example.com",
		"IUSE": "",
		"KEYWORDS": "~amd64 ~x86",
		"LICENSE": "MIT",
		"RDEPEND": "",
		"SLOT": "0",
		"SRC_URI": "https://example.com/${P}.tar.gz"
	}
}
