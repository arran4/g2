test: Repositories JSON to XML serialization
-- input.json --
{
	"XMLName": {
		"Space": "",
		"Local": "repositories"
	},
	"Version": "1.0",
	"Repositories": [
		{
			"Priority": "10",
			"Quality": "testing",
			"Status": "unofficial",
			"Name": "test-repo",
			"Descriptions": [
				{
					"Text": "A test repository",
					"Lang": "en"
				}
			],
			"LongDescriptions": null,
			"Homepage": "https://example.com",
			"Owners": [
				{
					"Type": "person",
					"Email": "owner@example.com",
					"Name": "Owner"
				}
			],
			"Sources": [
				{
					"Text": "https://example.com/repo.git",
					"Type": "git"
				}
			],
			"Feeds": [
				"https://example.com/feed.xml"
			]
		}
	]
}
-- expected.xml --
<repositories version="1.0">
	<repo priority="10" quality="testing" status="unofficial">
		<name>test-repo</name>
		<description lang="en">A test repository</description>
		<homepage>https://example.com</homepage>
		<owner type="person">
			<email>owner@example.com</email>
			<name>Owner</name>
		</owner>
		<source type="git">https://example.com/repo.git</source>
		<feed>https://example.com/feed.xml</feed>
	</repo>
</repositories>
