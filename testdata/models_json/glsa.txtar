test: GLSA JSON to XML serialization
-- input.json --
{
	"XMLName": {
		"Space": "",
		"Local": "glsa"
	},
	"ID": "200311-01",
	"Title": "Buffer overflow",
	"Synopsis": "Small description",
	"Product": {
		"Text": "openssl",
		"Type": "ebuild"
	},
	"Announced": "2003-11-20",
	"Revised": {
		"Text": "2003-11-20",
		"Count": "01"
	},
	"Bugs": [
		"12345"
	],
	"Access": "Remote",
	"Affected": {
		"Packages": [
			{
				"Name": "dev-libs/openssl",
				"Auto": "yes",
				"Arch": "*",
				"Vulnerable": [
					{
						"Text": "0.9.6k",
						"Range": "lt",
						"Slot": "*"
					}
				],
				"Unaffected": [
					{
						"Text": "0.9.6k",
						"Range": "ge",
						"Slot": "*",
						"Name": ""
					}
				]
			}
		],
		"Services": null
	},
	"Background": {
		"Text": "\n\t\t\u003cp\u003eBackground desc\u003c/p\u003e\n\t"
	},
	"Description": {
		"Text": "\n\t\t\u003cp\u003eSecurity issue\u003c/p\u003e\n\t"
	},
	"Impact": {
		"Text": "\n\t\t\u003cp\u003eImpact desc\u003c/p\u003e\n\t",
		"Type": "normal"
	},
	"Workaround": {
		"Text": "\n\t\t\u003cp\u003eWorkaround desc\u003c/p\u003e\n\t"
	},
	"Resolution": {
		"Text": "\n\t\t\u003cp\u003eResolution desc\u003c/p\u003e\n\t"
	},
	"References": {
		"URIs": [
			{
				"Text": "Example",
				"Link": "http://example.com"
			}
		]
	},
	"License": {
		"Text": "GPL-2"
	},
	"Metadata": [
		{
			"Text": "Level 1\u003cmetadata tag=\"nested\"\u003etrue\u003c/metadata\u003e",
			"Tag": "approved",
			"Revision": "",
			"Author": "",
			"Timestamp": ""
		}
	]
}
-- expected.xml --
<glsa id="200311-01">
	<title>Buffer overflow</title>
	<synopsis>Small description</synopsis>
	<product type="ebuild">openssl</product>
	<announced>2003-11-20</announced>
	<revised count="01">2003-11-20</revised>
	<bug>12345</bug>
	<access>Remote</access>
	<affected>
		<package name="dev-libs/openssl" auto="yes" arch="*">
			<vulnerable range="lt" slot="*">0.9.6k</vulnerable>
			<unaffected range="ge" slot="*">0.9.6k</unaffected>
		</package>
	</affected>
	<background>
		<p>Background desc</p>
	</background>
	<description>
		<p>Security issue</p>
	</description>
	<impact type="normal">
		<p>Impact desc</p>
	</impact>
	<workaround>
		<p>Workaround desc</p>
	</workaround>
	<resolution>
		<p>Resolution desc</p>
	</resolution>
	<references>
		<uri link="http://example.com">Example</uri>
	</references>
	<license>GPL-2</license>
	<metadata tag="approved">Level 1<metadata tag="nested">true</metadata></metadata>
</glsa>
