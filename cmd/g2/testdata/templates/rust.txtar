-- input.json --
{
  "EAPI": "8",
  "Description": "A short description",
  "Homepage": "https://example.com",
  "SrcURI": "https://example.com/${P}.tar.gz",
  "License": "GPL-2",
  "Slot": "0",
  "Keywords": "~amd64",
  "Depend": "",
  "RDepend": "",
  "BDepend": "",
  "Crates": "rand-0.8.5"
}
-- output.ebuild --
EAPI=8

CRATES="
rand-0.8.5"

inherit cargo

DESCRIPTION="A short description"
HOMEPAGE="https://example.com"
SRC_URI="https://example.com/${P}.tar.gz
	${CARGO_CRATE_URIS}"

LICENSE="GPL-2"
SLOT="0"
KEYWORDS="~amd64"

DEPEND=""
RDEPEND=""
BDEPEND=""

src_unpack() {
	cargo_src_unpack
}

src_compile() {
	cargo_src_compile
}

src_install() {
	cargo_src_install
}
