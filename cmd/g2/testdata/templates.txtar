-- default.ebuild --
EAPI=8

DESCRIPTION="A short description"
HOMEPAGE="https://example.com"
SRC_URI="https://example.com/${P}.tar.gz"

LICENSE="GPL-2"
SLOT="0"
KEYWORDS="~amd64"

DEPEND=""
RDEPEND=""
BDEPEND=""

src_compile() {
	emake
}

src_install() {
	emake DESTDIR="${D}" install
}
-- make.ebuild --
EAPI=8

DESCRIPTION="A short description"
HOMEPAGE="https://example.com"
SRC_URI="https://example.com/${P}.tar.gz"

LICENSE="GPL-2"
SLOT="0"
KEYWORDS="~amd64"

DEPEND=""
RDEPEND=""
BDEPEND=""

src_compile() {
	emake
}

src_install() {
	emake DESTDIR="${D}" install
}
-- go.ebuild --
EAPI=8

inherit go-module

DESCRIPTION="A short description"
HOMEPAGE="https://example.com"
SRC_URI="https://example.com/${P}.tar.gz"

LICENSE="GPL-2"
SLOT="0"
KEYWORDS="~amd64"

DEPEND=""
RDEPEND=""
BDEPEND=""

src_compile() {
	ego build -o bin/app
}

src_install() {
	dobin bin/app
}
-- rust.ebuild --
EAPI=8

CRATES="
rand-0.8.5"

inherit cargo

DESCRIPTION="A short description"
HOMEPAGE="https://example.com"
SRC_URI="https://example.com/${P}.tar.gz
	${CARGO_CRATE_URIS}"

LICENSE="GPL-2"
SLOT="0"
KEYWORDS="~amd64"

DEPEND=""
RDEPEND=""
BDEPEND=""

src_unpack() {
	cargo_src_unpack
}

src_compile() {
	cargo_src_compile
}

src_install() {
	cargo_src_install
}
-- cmake.ebuild --
EAPI=8

inherit cmake

DESCRIPTION="A short description"
HOMEPAGE="https://example.com"
SRC_URI="https://example.com/${P}.tar.gz"

LICENSE="GPL-2"
SLOT="0"
KEYWORDS="~amd64"

DEPEND=""
RDEPEND=""
BDEPEND=""

src_configure() {
	local mycmakeargs=(
		-DCMAKE_INSTALL_PREFIX="${EPREFIX}/usr"
	)
	cmake_src_configure
}
-- cmake-kde.ebuild --
EAPI=8

ECM_TEST="true"
inherit ecm

DESCRIPTION="A short description"
HOMEPAGE="https://kde.org"
SRC_URI="mirror://kde/stable/${PN}/${PV}/${P}.tar.xz"

LICENSE="GPL-2"
SLOT="0"
KEYWORDS="~amd64"

DEPEND=""
RDEPEND="${DEPEND}"
BDEPEND=""
-- python.ebuild --
EAPI=8

PYTHON_COMPAT=( python3_{10..12} )
DISTUTILS_USE_PEP517=setuptools

inherit distutils-r1

DESCRIPTION="A short description"
HOMEPAGE="https://example.com"
SRC_URI=""

LICENSE="GPL-2"
SLOT="0"
KEYWORDS="~amd64"

DEPEND=""
RDEPEND=""
BDEPEND=""
-- python-single.ebuild --
EAPI=8

PYTHON_COMPAT=( python3_{10..12} )

inherit python-single-r1

DESCRIPTION="A short description"
HOMEPAGE="https://example.com"
SRC_URI=""

LICENSE="GPL-2"
SLOT="0"
KEYWORDS="~amd64"

REQUIRED_USE="${PYTHON_REQUIRED_USE}"
DEPEND="${PYTHON_DEPS} "
RDEPEND="${PYTHON_DEPS} "
BDEPEND=""

src_install() {
	python_doscript myscript.py
}
